<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="450" Width="300"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поле ввода/вывода -->
        <TextBox x:Name="DisplayTextBox" Grid.Row="0" FontSize="32" 
                 HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                 Margin="0,0,0,10" IsReadOnly="True" Background="White" 
                 Text="0" />

        <!-- Панель кнопок -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Первая строка -->
            <Button x:Name="ClearButton" Grid.Row="0" Grid.Column="0" Content="C" FontSize="20" Click="ClearButton_Click"/>
            <Button x:Name="ClearEntryButton" Grid.Row="0" Grid.Column="1" Content="CE" FontSize="20" Click="ClearEntryButton_Click"/>
            <Button x:Name="SignButton" Grid.Row="0" Grid.Column="2" Content="+/-" FontSize="20" Click="SignButton_Click"/>
            <Button x:Name="DivideButton" Grid.Row="0" Grid.Column="3" Content="÷" FontSize="20" Click="OperationButton_Click"/>

            <!-- Вторая строка -->
            <Button x:Name="Button7" Grid.Row="1" Grid.Column="0" Content="7" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button8" Grid.Row="1" Grid.Column="1" Content="8" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button9" Grid.Row="1" Grid.Column="2" Content="9" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="MultiplyButton" Grid.Row="1" Grid.Column="3" Content="×" FontSize="20" Click="OperationButton_Click"/>

            <!-- Третья строка -->
            <Button x:Name="Button4" Grid.Row="2" Grid.Column="0" Content="4" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button5" Grid.Row="2" Grid.Column="1" Content="5" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button6" Grid.Row="2" Grid.Column="2" Content="6" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="SubtractButton" Grid.Row="2" Grid.Column="3" Content="-" FontSize="20" Click="OperationButton_Click"/>

            <!-- Четвёртая строка -->
            <Button x:Name="Button1" Grid.Row="3" Grid.Column="0" Content="1" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button2" Grid.Row="3" Grid.Column="1" Content="2" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="Button3" Grid.Row="3" Grid.Column="2" Content="3" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="AddButton" Grid.Row="3" Grid.Column="3" Content="+" FontSize="20" Click="OperationButton_Click"/>

            <!-- Пятая строка -->
            <Button x:Name="Button0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" FontSize="20" Click="NumberButton_Click"/>
            <Button x:Name="DecimalButton" Grid.Row="4" Grid.Column="2" Content="." FontSize="20" Click="DecimalButton_Click"/>
            <Button x:Name="EqualsButton" Grid.Row="4" Grid.Column="3" Content="=" FontSize="20" Click="EqualsButton_Click"/>
        </Grid>
    </Grid>
</Window>