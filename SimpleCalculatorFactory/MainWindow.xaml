<Window x:Class="SimpleCalculatorFactory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="500" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="DisplayTextBox" FontSize="24" 
                 Margin="5" IsReadOnly="True" 
                 TextAlignment="Right" Text="0"/>

        <UniformGrid x:Name="ButtonsGrid" Grid.Row="1" Rows="5" Columns="5" Margin="5"/>
    </Grid>
</Window>